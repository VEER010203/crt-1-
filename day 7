#include <iostream>
using namespace std;

class Parent {
    protected: 
    int secretCode =0001;
};
 class child : public Parent {
     public:
     void accessOfSecretCode (){
         cout << "secretCode of the locker is "<< secretCode;
         
     }
 };
 
 
int main(){
        child obj1;
        obj1.accessOfSecretCode();
}







