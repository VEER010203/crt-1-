// problem 4 
// swap values of 2 variables 
#include<iostream>
using namespace std;

int main (){
    int a;
    int b;
    cin >>a >> b;
    
    int temp= a;
    a=b;
    b=temp;
     cout << a << "\n"<< b << endl ;
     return 0;
     
}


