// problem 5 
// Area of shapes 
#include<iostream>
using namespace std;

int main (){
 int choice ;
 cin>> choice ;
  
  if (choice ==1){
      double radius ;
      cin>> radius ;
      cout <<3.14 * radius * radius << endl ;
  }  else if ( choice == 2 ){
      double length , width;
      cin >> length >> width;
      cout << length * width << endl ;
  }else if (choice == 3){
      double base, height ;
      cin >> base >> height;
      cout << 0.5* base * height << endl ;
  } else {
      cout <<"invalid choice "<< endl ;
  }
  return 0;
}

// problem 6
// Calculate the sum and average of 3 numbers
#include <iostream>

using namespace std;

int main() {
    double p1; 
    double q2;
    double r3;
    double sum, average;

    cin >> p1 >> q2 >> r3 ;
    sum = p1 + q2+ r3;
    average = sum / 3.0;

  
    cout << "Sum: " << sum << endl;
    cout << "Average: " << average << endl;

    return 0;
}
