class Animal{
 public:
 virtual  void sound (){                    // virtual use 
       cout << " animal make sound ";
   }
};

class Dog : public Animal{
    public:
    void sound() override {                     // override 
        cout << "dog make a sound "<<"\n";
    }
};

 class Cat : public Animal{

    public:
    void sound()override  {                     //override
        cout << "cat make a sound"<< "\n";
    }
 };
 
  int main (){
      Dog d;
      Cat c;
      d.sound();
      c.sound();
  }



