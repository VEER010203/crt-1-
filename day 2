// types of poymorphism --2.1
// function overloading

#include <iostream>
using namespace std;

class Math {
public:
    // First version: 2 integers
    void add(int a, int b) {
        cout << a * b << "\n";
    }

    // Second version: 3 integers
    void add(int a, int b, int c) {
        cout << a * b * c << "\n";
    }

    // Third version: 2 doubles
    void add(double a, double b) {
        cout << a * b << "\n";
    }
}; // The class must close AFTER all functions are defined

int main() {
    Math m;
    
    m.add(5, 2);      
    m.add(8, 8, 8);    
    m.add(8.2, 9.9);   

    return 0;
}




