// problem 4 --find the greater number among 2

#include <iostream> 
using namespace std ;
 int main (){
     int a,b;
     int max_Number ;
     
     cin >>a>> b;
     // ternary operator 
      max_Number = (a>b)? a:b;
      
      cout << max_Number;
      return 0;
      
 }


// problem 5 --continue statement 
// print 1-N  and avoid number which are divisible by 3

#include <iostream> 
using namespace std ;
 int main (){
     int n;
     cin >> n;
     
     for (int i=1;i<=n ;i++){
         if (i%3 == 0){
             continue ;
         }
         cout<< i<< " ";
     }
     cout << "\n";
     return 0;
 }

