//problem 6
// Print  : hollow triangle 

#include <iostream> 
using namespace std;
int main (){
    
     
     for (int i = 1; i<=9; i++){
         for (int j=1; j<=9 ; j++){
             cout<< " ";
         if(i==1|| j==1||i==9||j==9){
             cout<< "*";
         }else{
             cout << " ";
         }
         }
        cout <<"\n";
     }
     return 0;
}



//problem 7
// print a pyramid

#include <iostream>
using namespace std;

int main() {
    int n = 5; 
    for (int i = 1; i <= n; i++) {
        
        for (int j = 1; j <= n - i; j++) {
            cout << " ";
        }

       
        for (int k = 1; k <= (2 * i - 1); k++) {
            cout << "*";
        }

        
        cout << endl;
    }

    return 0;
}
