//Print -1
// Print -  1 to 10 ,10 number of times ]

#include <iostream> 
using namespace std;
int main (){
     
     for (int i = 1; i<=10 ; i++){
         for (int j=1; j<=10 ; j++){
             cout << j << " ";
         }
        cout << "\n";
        
     }
     return 0;
}


